rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Expense proof images
    match /expenses/{groupId}/{expenseId}/{fileName} {
      // Allow upload only by authenticated group members
      allow write: if isAuthenticated() &&
        // Check if user is group member (this would need to be verified via Firestore)
        resource == null && // Only allow new uploads
        request.resource.size < 10 * 1024 * 1024 && // 10MB limit
        request.resource.contentType.matches('image/.*');
      
      // Allow read by authenticated group members
      allow read: if isAuthenticated();
      
      // Allow delete by uploader or group admin
      allow delete: if isAuthenticated();
    }
    
    // User profile images
    match /users/{userId}/profile/{fileName} {
      allow write: if isAuthenticated() && 
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB limit
        request.resource.contentType.matches('image/.*');
      
      allow read: if isAuthenticated();
      
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Group images
    match /groups/{groupId}/{fileName} {
      allow write: if isAuthenticated() &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB limit
        request.resource.contentType.matches('image/.*');
      
      allow read: if isAuthenticated();
      
      allow delete: if isAuthenticated();
    }
  }
}