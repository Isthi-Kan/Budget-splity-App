rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - Users can read/write their own data + others can read basic profile info
    match /users/{userId} {
      // Users can always read/write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Authenticated users can read basic profile data (name, email) of other users
      // This is needed for group summaries and expense tracking
      allow read: if request.auth != null;
    }
    
    // Groups collection - Fixed rules for group creation and management
    match /groups/{groupId} {
      // Allow reading if user is a member OR if querying by invite code
      allow read: if request.auth != null && 
        (request.auth.uid in resource.data.members ||
         resource.data.inviteCode != null);
      
      // Allow creation if user is the host and in members array
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.hostId &&
        request.auth.uid in request.resource.data.members;
      
      // Allow updates if user is the host or a member, OR if user is joining the group
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.hostId ||
         request.auth.uid in resource.data.members ||
         (request.auth.uid in request.resource.data.members && 
          !(request.auth.uid in resource.data.members))); // User is being added to members
      
      // Allow deletion only by host
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.hostId;
    }
    
    // Expenses collection - Simplified rules
    match /expenses/{groupId}/expenses/{expenseId} {
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }
    
    // Group summaries - Group members can read and write
    match /groupSummaries/{groupId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }
    
    // Settlements - group members can read/write
    match /settlements/{groupId}/settlements/{settlementId} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }
  }
}

/* 

📋 INSTRUCTIONS TO APPLY THESE RULES:

1. Go to Firebase Console: https://console.firebase.google.com/
2. Select your project: splitify-a9448
3. Go to "Firestore Database" in the left sidebar
4. Click on "Rules" tab
5. Replace the existing rules with the rules above
6. Click "Publish" to save the changes

⚠️ IMPORTANT: Make sure to test after publishing!

CURRENT ISSUE:
Your Firebase queries are failing with "Missing or insufficient permissions"
This is because the default Firestore rules are too restrictive.

*/